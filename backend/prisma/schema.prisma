// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  colour     String
  pin        String?
  is_admin   Boolean  @default(false)
  created_at DateTime @default(now())

  sessions         Session[]
  activatedLogs    SessionZoneLog[] @relation("ActivatedBy")
  deactivatedLogs  SessionZoneLog[] @relation("DeactivatedBy")
}

model Zone {
  id           Int      @id @default(autoincrement())
  name         String
  kwh_per_hour Float
  created_at   DateTime @default(now())

  sessionZoneLogs    SessionZoneLog[]
  zoneCombinations   ZoneCombinationZone[]
  sessions           SessionZone[]
}

model ZoneCombination {
  id           Int      @id @default(autoincrement())
  label        String
  kwh_per_hour Float

  zones ZoneCombinationZone[]
}

model ZoneCombinationZone {
  id                Int             @id @default(autoincrement())
  zone_combination  ZoneCombination @relation(fields: [zone_combination_id], references: [id], onDelete: Cascade)
  zone_combination_id Int
  zone              Zone            @relation(fields: [zone_id], references: [id], onDelete: Cascade)
  zone_id           Int

  @@unique([zone_combination_id, zone_id])
}

model Session {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int
  start_time DateTime
  end_time   DateTime?
  edited     Boolean   @default(false)
  created_at DateTime  @default(now())

  zones           SessionZone[]
  sessionZoneLogs SessionZoneLog[]
}

model SessionZone {
  id         Int     @id @default(autoincrement())
  session    Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  session_id Int
  zone       Zone    @relation(fields: [zone_id], references: [id], onDelete: Cascade)
  zone_id    Int

  @@unique([session_id, zone_id])
}

model SessionZoneLog {
  id               Int       @id @default(autoincrement())
  session          Session   @relation(fields: [session_id], references: [id], onDelete: Cascade)
  session_id       Int
  zone             Zone      @relation(fields: [zone_id], references: [id], onDelete: Cascade)
  zone_id          Int
  activatedBy      User      @relation("ActivatedBy", fields: [activated_by], references: [id])
  activated_by     Int
  activated_at     DateTime
  deactivatedBy    User?     @relation("DeactivatedBy", fields: [deactivated_by], references: [id])
  deactivated_by   Int?
  deactivated_at   DateTime?
}

model Settings {
  id                   Int     @id @default(1)
  electricity_rate     Float   @default(0.25)
  auto_off_duration    Int     @default(120)
  household_name       String  @default("Our Home")
  require_confirmation Boolean @default(true)
}
