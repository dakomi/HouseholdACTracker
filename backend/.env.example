# ── Core ─────────────────────────────────────────────────────────────────────
# SQLite (local / Raspberry Pi):
DATABASE_URL="file:./dev.db"
# PostgreSQL (Railway / Render / Fly.io) – Railway injects this automatically:
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Port the HTTP server listens on.
# PaaS platforms (Railway, Render, …) inject $PORT automatically at runtime.
PORT=3001

# Public URL of the deployed app – used for CORS and Socket.io origin checks.
# • Local dev:            http://localhost:3000
# • Single-service PaaS:  https://your-app.railway.app  (same as the app URL)
# • Separate frontend:    https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Facebook Messenger bot (optional) ────────────────────────────────────────
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token_here
MESSENGER_VERIFY_TOKEN=your_verify_token_here
MESSENGER_APP_SECRET=your_app_secret_here
